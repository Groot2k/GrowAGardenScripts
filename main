-- ================================================
-- PET SCANNER (Backpack & Data) - UPDATED
-- ================================================
local function ScanPets()
    local pets = {}
    local addedInstances = {} -- Untuk mencegah duplikat

    local function extractData(item)
        if not item or addedInstances[item] then return end
        
        -- Cek apakah ini tool pet atau objek data pet
        if item:IsA("Tool") or item:IsA("Model") or item:IsA("Configuration") or item:IsA("Folder") then
            local petName = item.Name
            
            -- Cek Level dari berbagai kemungkinan (Attribute atau Value Object)
            local level = item:GetAttribute("Level") 
                or item:GetAttribute("PetLevel") 
                or (item:FindFirstChild("Level") and item.Level:IsA("ValueBase") and item.Level.Value)
                or (item:FindFirstChild("PetLevel") and item.PetLevel:IsA("ValueBase") and item.PetLevel.Value)
                or 1

            -- Cek Weight dari berbagai kemungkinan
            local weight = item:GetAttribute("Weight") 
                or item:GetAttribute("PetWeight") 
                or (item:FindFirstChild("Weight") and item.Weight:IsA("ValueBase") and item.Weight.Value)
                or 0.0

            -- Masukkan ke list jika item memiliki nama yang valid (bukan folder sistem)
            if petName ~= "Pets" and petName ~= "Data" then
                table.insert(pets, {
                    Name = petName,
                    Instance = item,
                    Level = tonumber(level) or 1,
                    Weight = tonumber(weight) or 0.0,
                })
                addedInstances[item] = true
            end
        end
    end

    -- 1. Scan Backpack & Character
    local containers = {LocalPlayer:FindFirstChild("Backpack"), LocalPlayer.Character}
    for _, container in ipairs(containers) do
        if container then
            for _, item in ipairs(container:GetChildren()) do
                extractData(item)
            end
        end
    end

    -- 2. Scan Folder Inventory (Mencari di dalam folder-folder umum)
    local possibleFolders = {"Pets", "PetInventory", "OwnedPets", "Data", "PlayerGui"}
    for _, folderName in ipairs(possibleFolders) do
        local target = LocalPlayer:FindFirstChild(folderName)
        if target then
            -- Gunakan GetDescendants jika pet berada di dalam sub-folder
            for _, item in ipairs(target:GetDescendants()) do
                extractData(item)
            end
        end
    end

    return pets
end

-- ================================================
-- FPS BOOST
-- ================================================
local originalSettings = {
    GlobalShadows = Lighting.GlobalShadows,
    Brightness = Lighting.Brightness,
    FogEnd = Lighting.FogEnd,
    FogStart = Lighting.FogStart,
}

local function ApplyFPSBoost()
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.FogStart = 9e9
    Lighting.Brightness = 0

    for _, v in ipairs(Lighting:GetChildren()) do
        if v:IsA("Sky") or v:IsA("Atmosphere") or v:IsA("BloomEffect")
            or v:IsA("BlurEffect") or v:IsA("ColorCorrectionEffect")
            or v:IsA("SunRaysEffect") or v:IsA("DepthOfFieldEffect") then
            v.Enabled = false
        end
    end

    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Trail")
            or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
            v.Enabled = false
        end
    end
end

local function RemoveFPSBoost()
    settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
    Lighting.GlobalShadows = originalSettings.GlobalShadows
    Lighting.Brightness = originalSettings.Brightness
    Lighting.FogEnd = originalSettings.FogEnd
    Lighting.FogStart = originalSettings.FogStart
end

