-- Main Loop Auto Elephant
RunService.Heartbeat:Connect(function()
    if not Config.AutoElephantEnabled then return end

    local elephantType = Config.ElephantTeam.ElephantPet
    local levelTarget = Config.LevelBeforeElephant[elephantType] or 40
    local weightTarget = Config.TargetWeight[elephantType] or 5.5

    -- Logika:
    -- 1. Cek level target pet
    -- 2. Jika belum mencapai level, gunakan Leveling Team
    -- 3. Jika sudah mencapai level, ganti ke Elephant Team
    -- 4. Cek berat, jika sudah mencapai target weight → selesai

