Section("🟢  PET SELECTION", C.Blue)
local function PetSlot(txt, onSel)
    local f = Card(44)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.5, 0, 1, 0)
    lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = txt
    lbl.TextColor3 = C.TextDim
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = f
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 80, 0, 30)
    btn.Position = UDim2.new(1, -90, 0.5, -15)
    btn.BackgroundColor3 = C.AccentDim
    btn.Text = "Select"
    btn.TextColor3 = C.White
    btn.Parent = f
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.MouseButton1Click:Connect(function()
        OpenPetSelector(function(pet)
            btn.Text = pet.Name
            onSel(pet)
        end)
    end)
end

PetSlot("Target Pet", function(p) Config.Target.Pet = p end)
PetSlot("Elephant Pet", function(p) Config.ElephantTeam.ElephantPet = p end)

Section("⚙️  SETTINGS", C.Purple)
InputBox("Level Goal", 50, function(v) Config.Target.LevelBefore = tonumber(v) or 50 end)
InputBox("Weight Goal", 3.5, function(v) Config.Target.Weight = tonumber(v) or 3.5 end)

Toggle("Enable Auto Elephant", false, function(v)
    Config.AutoElephant = v
end)

-- LOOP LOGIC
RunService.Heartbeat:Connect(function()
    if not Config.AutoElephant or not Config.Target.Pet then return end
    
    local pet = Config.Target.Pet
    local currentLevel = pet.Instance:GetAttribute("Level") or 1
    local currentWeight = pet.Instance:GetAttribute("Weight") or 0
    
    if currentWeight >= Config.Target.Weight then
        StatusText.Text = "✅ Goal Reached!"
        Config.AutoElephant = false
        return
    end

    if currentLevel < Config.Target.LevelBefore then
        StatusText.Text = "🟢 Leveling: " .. pet.Name .. " (Lv." .. currentLevel .. ")"
    else
        StatusText.Text = "🐘 Elephant: " .. pet.Name .. " (" .. currentWeight .. "kg)"
    end
end)

-- DRAGGABLE GUI
local dragging, dragStart, startPos
TitleBar.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true dragStart = inp.Position startPos = MainFrame.Position
    end
end)
UserInputService.InputChanged:Connect(function(inp)
    if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
        local d = inp.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
    end
end)
TitleBar.InputEnded:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

print("✅ [GaG Script] Updated & Loaded!")
