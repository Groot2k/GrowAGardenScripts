-- Populate pet list
local currentCallback = nil

local function PopulatePetList()
    for _, v in ipairs(PetScroll:GetChildren()) do
        if v:IsA("TextButton") or v:IsA("Frame") then v:Destroy() end
    end

    local pets = ScanPets()

    if #pets == 0 then
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1, 0, 0, 36)
        empty.BackgroundTransparency = 1
        empty.Text = "❌ Tidak ada pet ditemukan di backpack"
        empty.TextColor3 = C.Red
        empty.Font = Enum.Font.Gotham
        empty.TextSize = 12
        empty.ZIndex = 22
        empty.LayoutOrder = 1
        empty.Parent = PetScroll
        return
    end

    for i, pet in ipairs(pets) do
        local row = Instance.new("TextButton")
        row.Size = UDim2.new(1, 0, 0, 48)
        row.BackgroundColor3 = C.Card
        row.BorderSizePixel = 0
        row.Text = ""
        row.ZIndex = 22
        row.LayoutOrder = i
        row.Parent = PetScroll
        Instance.new("UICorner", row).CornerRadius = UDim.new(0, 7)

        local icon = Instance.new("TextLabel")
        icon.Size = UDim2.new(0, 36, 1, 0)
        icon.Position = UDim2.new(0, 6, 0, 0)
        icon.BackgroundTransparency = 1
        icon.Text = "🐾"
        icon.TextScaled = true
        icon.ZIndex = 23
        icon.Parent = row

        local nameL = Instance.new("TextLabel")
        nameL.Size = UDim2.new(0.55, 0, 0.55, 0)
        nameL.Position = UDim2.new(0, 46, 0, 4)
        nameL.BackgroundTransparency = 1
        nameL.Text = pet.Name
        nameL.TextColor3 = C.Text
        nameL.Font = Enum.Font.GothamBold
        nameL.TextSize = 13
        nameL.TextXAlignment = Enum.TextXAlignment.Left
        nameL.ZIndex = 23
        nameL.Parent = row

        local infoL = Instance.new("TextLabel")
        infoL.Size = UDim2.new(0.55, 0, 0.4, 0)
        infoL.Position = UDim2.new(0, 46, 0.55, 0)
        infoL.BackgroundTransparency = 1
        infoL.Text = string.format("Lv.%d  |  %.2f kg", pet.Level, pet.Weight)
        infoL.TextColor3 = C.TextDim
        infoL.Font = Enum.Font.Gotham
        infoL.TextSize = 11
        infoL.TextXAlignment = Enum.TextXAlignment.Left
        infoL.ZIndex = 23
        infoL.Parent = row

        local selBtn = Instance.new("TextButton")
        selBtn.Size = UDim2.new(0, 64, 0, 30)
        selBtn.Position = UDim2.new(1, -70, 0.5, -15)
        selBtn.BackgroundColor3 = C.Accent
        selBtn.Text = "Pilih"
        selBtn.TextColor3 = C.White
        selBtn.Font = Enum.Font.GothamBold
        selBtn.TextSize = 12
        selBtn.BorderSizePixel = 0
        selBtn.ZIndex = 24
        selBtn.Parent = row
        Instance.new("UICorner", selBtn).CornerRadius = UDim.new(0, 6)

        selBtn.MouseButton1Click:Connect(function()
            if currentCallback then
                currentCallback(pet)
            end
            PetPopup.Visible = false
        end)

        row.MouseButton1Click:Connect(function()
            if currentCallback then
                currentCallback(pet)
            end
            PetPopup.Visible = false
        end)
    end
end

local function OpenPetSelector(callback)
    currentCallback = callback
    PopulatePetList()
    PetPopup.Visible = true
end

PopupClose.MouseButton1Click:Connect(function()
    PetPopup.Visible = false
end)

RefreshBtn.MouseButton1Click:Connect(function()
    PopulatePetList()
end)

