local function Section(title, color)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1, 0, 0, 28)
    f.BackgroundTransparency = 1
    f.LayoutOrder = NextOrder()
    f.Parent = Scroll

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = title
    lbl.TextColor3 = color or C.Accent
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 13
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = f
    return f
end

local function Divider()
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1, 0, 0, 1)
    f.BackgroundColor3 = C.Border
    f.BorderSizePixel = 0
    f.LayoutOrder = NextOrder()
    f.Parent = Scroll
end

local function Card(height)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1, 0, 0, height or 44)
    f.BackgroundColor3 = C.Card
    f.BorderSizePixel = 0
    f.LayoutOrder = NextOrder()
    f.Parent = Scroll
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 8)
    return f
end

local function Toggle(labelText, default, callback)
    local f = Card(44)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.7, 0, 1, 0)
    lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = labelText
    lbl.TextColor3 = C.Text
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 13
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = f

    local state = default or false
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 56, 0, 28)
    btn.Position = UDim2.new(1, -64, 0.5, -14)
    btn.BackgroundColor3 = state and C.Accent or C.Border
    btn.Text = state and "ON" or "OFF"
    btn.TextColor3 = C.White
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 13
    btn.BorderSizePixel = 0
    btn.Parent = f
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

    local function SetState(v)
        state = v
        btn.BackgroundColor3 = state and C.Accent or C.Border
        btn.Text = state and "ON" or "OFF"
        if callback then callback(state) end
    end

    btn.MouseButton1Click:Connect(function()
        SetState(not state)
    end)

    return btn, SetState
end

local function InputBox(labelText, default, callback)
    local f = Card(44)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.52, 0, 1, 0)
    lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = labelText
    lbl.TextColor3 = C.TextDim
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = f

    local box = Instance.new("TextBox")
    box.Size = UDim2.new(0.45, -4, 0, 30)
    box.Position = UDim2.new(0.54, 0, 0.5, -15)
    box.BackgroundColor3 = C.Panel
    box.BorderSizePixel = 0
    box.Text = tostring(default or "")
    box.TextColor3 = C.Accent
    box.Font = Enum.Font.GothamBold
    box.TextSize = 13
    box.ClearTextOnFocus = false
    box.Parent = f
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 6)

    box.FocusLost:Connect(function()
        if callback then callback(box.Text) end
    end)
    return box
end

