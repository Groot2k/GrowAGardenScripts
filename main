local layoutOrder = 0
local function NextOrder()
    layoutOrder = layoutOrder + 1
    return layoutOrder
end

-- ================================================
-- UI HELPERS
-- ================================================
local function Section(title, color)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1, 0, 0, 28)
    f.BackgroundTransparency = 1
    f.LayoutOrder = NextOrder()
    f.Parent = Scroll
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = title
    lbl.TextColor3 = color or C.Accent
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 13
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = f
    return f
end

local function Card(height)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1, 0, 0, height or 44)
    f.BackgroundColor3 = C.Card
    f.LayoutOrder = NextOrder()
    f.Parent = Scroll
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 8)
    return f
end

local function Toggle(labelText, default, callback)
    local f = Card(44)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.7, 0, 1, 0)
    lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = labelText
    lbl.TextColor3 = C.Text
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 13
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = f
    local state = default or false
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 56, 0, 28)
    btn.Position = UDim2.new(1, -64, 0.5, -14)
    btn.BackgroundColor3 = state and C.Accent or C.Border
    btn.Text = state and "ON" or "OFF"
    btn.TextColor3 = C.White
    btn.Font = Enum.Font.GothamBold
    btn.Parent = f
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.BackgroundColor3 = state and C.Accent or C.Border
        btn.Text = state and "ON" or "OFF"
        if callback then callback(state) end
    end)
    return btn
end

local function InputBox(labelText, default, callback)
    local f = Card(44)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.5, 0, 1, 0)
    lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = labelText
    lbl.TextColor3 = C.TextDim
    lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = f
    local box = Instance.new("TextBox")
    box.Size = UDim2.new(0.45, -4, 0, 30)
    box.Position = UDim2.new(0.54, 0, 0.5, -15)
    box.BackgroundColor3 = C.Panel
    box.Text = tostring(default or "")
    box.TextColor3 = C.Accent
    box.Font = Enum.Font.GothamBold
    box.Parent = f
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 6)
    box.FocusLost:Connect(function() if callback then callback(box.Text) end end)
    return box
end

-- ================================================
-- PET SELECTOR POPUP
-- ================================================
local PetPopup = Instance.new("Frame")
PetPopup.Size = UDim2.new(0, 340, 0, 420)
PetPopup.Position = UDim2.new(0.5, -170, 0.5, -210)
PetPopup.BackgroundColor3 = C.Panel
PetPopup.Visible = false
PetPopup.ZIndex = 20
PetPopup.Parent = ScreenGui
Instance.new("UICorner", PetPopup).CornerRadius = UDim.new(0, 12)

local PetScroll = Instance.new("ScrollingFrame")
PetScroll.Size = UDim2.new(1, -16, 1, -100)
PetScroll.Position = UDim2.new(0, 8, 0, 92)
PetScroll.BackgroundColor3 = C.BG
PetScroll.ScrollBarThickness = 4
PetScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
PetScroll.ZIndex = 21
PetScroll.Parent = PetPopup
Instance.new("UIListLayout", PetScroll).Padding = UDim.new(0, 4)

local function PopulatePetList(callback)
    for _, v in ipairs(PetScroll:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end
    local pets = ScanPets()
    for _, pet in ipairs(pets) do
        local row = Instance.new("TextButton")
        row.Size = UDim2.new(1, -10, 0, 40)
        row.BackgroundColor3 = C.Card
        row.Text = pet.Name .. " (Lv." .. pet.Level .. ")"
        row.TextColor3 = C.Text
        row.ZIndex = 22
        row.Parent = PetScroll
        row.MouseButton1Click:Connect(function()
            callback(pet)
            PetPopup.Visible = false
        end)
    end
end

local function OpenPetSelector(callback)
    PopulatePetList(callback)
    PetPopup.Visible = true
end

