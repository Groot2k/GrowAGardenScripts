    Instance.new("UICorner", container).CornerRadius = UDim.new(0, 8)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.38, 0, 1, 0)
    lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = labelText
    lbl.TextColor3 = C.TextDim
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = container

    local valLbl = Instance.new("TextLabel")
    valLbl.Size = UDim2.new(0.38, 0, 1, 0)
    valLbl.Position = UDim2.new(0.37, 0, 0, 0)
    valLbl.BackgroundTransparency = 1
    valLbl.Text = "— Belum dipilih —"
    valLbl.TextColor3 = C.Accent
    valLbl.Font = Enum.Font.GothamBold
    valLbl.TextSize = 11
    valLbl.TextXAlignment = Enum.TextXAlignment.Left
    valLbl.Parent = container

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 58, 0, 30)
    btn.Position = UDim2.new(1, -64, 0.5, -15)
    btn.BackgroundColor3 = C.AccentDim
    btn.Text = "Pilih"
    btn.TextColor3 = C.White
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    btn.BorderSizePixel = 0
    btn.Parent = container
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

    btn.MouseButton1Click:Connect(function()
        OpenPetSelector(function(pet)
            valLbl.Text = pet.Name .. " Lv." .. pet.Level
            if onSelect then onSelect(pet) end
        end)
    end)

    return container, valLbl
end

