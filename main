-- ================================================
-- PET SCANNER (Backpack)
-- ================================================
local function ScanPets()
    local pets = {}
    local character = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")

    -- Cari dari karakter & backpack
    local containers = {}
    if character then table.insert(containers, character) end
    if backpack then table.insert(containers, backpack) end

    for _, container in ipairs(containers) do
        for _, item in ipairs(container:GetChildren()) do
            -- Sesuaikan kondisi ini dengan tag/attribute pet di game
            if item:IsA("Tool") or item:IsA("Model") then
                local petName = item.Name
                local level = 1
                local weight = 0.0

                -- Coba baca attribute jika ada
                if item:GetAttribute("Level") then
                    level = item:GetAttribute("Level")
                end
                if item:GetAttribute("Weight") then
                    weight = item:GetAttribute("Weight")
                end
                if item:GetAttribute("PetLevel") then
                    level = item:GetAttribute("PetLevel")
                end

                table.insert(pets, {
                    Name = petName,
                    Instance = item,
                    Level = level,
                    Weight = weight,
                })
            end
        end
    end

    -- Coba juga dari PlayerGui / DataStore jika ada folder khusus
    local petFolder = LocalPlayer:FindFirstChild("Pets")
        or LocalPlayer:FindFirstChild("PetInventory")
        or LocalPlayer:FindFirstChild("OwnedPets")
    if petFolder then
        for _, item in ipairs(petFolder:GetChildren()) do
            local petName = item.Name
            local level = item:GetAttribute("Level") or 1
            local weight = item:GetAttribute("Weight") or 0.0
            -- Cek duplikat
            local dup = false
            for _, p in ipairs(pets) do
                if p.Instance == item then dup = true break end
            end
            if not dup then
                table.insert(pets, {
                    Name = petName,
                    Instance = item,
                    Level = level,
                    Weight = weight,
                })
            end
        end
    end

    return pets
end

-- ================================================
-- FPS BOOST
-- ================================================
local originalSettings = {
    GlobalShadows = Lighting.GlobalShadows,
    Brightness = Lighting.Brightness,
    FogEnd = Lighting.FogEnd,
    FogStart = Lighting.FogStart,
}

local function ApplyFPSBoost()
    -- Render Quality
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01

    -- Lighting
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.FogStart = 9e9
    Lighting.Brightness = 0

    -- Hapus efek atmosphere & sky
    for _, v in ipairs(Lighting:GetChildren()) do
        if v:IsA("Sky") or v:IsA("Atmosphere") or v:IsA("BloomEffect")
            or v:IsA("BlurEffect") or v:IsA("ColorCorrectionEffect")
            or v:IsA("SunRaysEffect") or v:IsA("DepthOfFieldEffect") then
            v:Destroy()
        end
    end

    -- Hapus particle & efek di workspace
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Trail")
            or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
            v.Enabled = false
        end
        if v:IsA("Sky") or v:IsA("Atmosphere") then
            v:Destroy()
        end
    end

    -- Set texture off untuk semua BasePart non-essential
    -- (opsional, hati-hati bisa ubah tampilan)
    -- for _, v in ipairs(workspace:GetDescendants()) do
    --     if v:IsA("BasePart") then
    --         v.Material = Enum.Material.SmoothPlastic
    --         v.CastShadow = false
    --     end
    -- end
end

local function RemoveFPSBoost()
    settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
    Lighting.GlobalShadows = originalSettings.GlobalShadows
    Lighting.Brightness = originalSettings.Brightness
    Lighting.FogEnd = originalSettings.FogEnd
    Lighting.FogStart = originalSettings.FogStart
    Lighting.GlobalShadows = true
end

