end)

-- Elephant Type dropdown sederhana
local elTypeCard = Card(44)
local elTypeLbl = Instance.new("TextLabel")
elTypeLbl.Size = UDim2.new(0.5, 0, 1, 0)
elTypeLbl.Position = UDim2.new(0, 10, 0, 0)
elTypeLbl.BackgroundTransparency = 1
elTypeLbl.Text = "Tipe Elephant"
elTypeLbl.TextColor3 = C.TextDim
elTypeLbl.Font = Enum.Font.Gotham
elTypeLbl.TextSize = 12
elTypeLbl.TextXAlignment = Enum.TextXAlignment.Left
elTypeLbl.Parent = elTypeCard

local elTypeOptions = {"Elephant", "RBH Elephant"}
local elTypeIdx = 1
local elTypeBtn = Instance.new("TextButton")
elTypeBtn.Size = UDim2.new(0.45, -4, 0, 30)
elTypeBtn.Position = UDim2.new(0.54, 0, 0.5, -15)
elTypeBtn.BackgroundColor3 = C.Panel
elTypeBtn.Text = "◀  " .. elTypeOptions[elTypeIdx] .. "  ▶"
elTypeBtn.TextColor3 = C.Accent
elTypeBtn.Font = Enum.Font.GothamBold
elTypeBtn.TextSize = 12
elTypeBtn.BorderSizePixel = 0
elTypeBtn.Parent = elTypeCard
Instance.new("UICorner", elTypeBtn).CornerRadius = UDim.new(0, 6)

elTypeBtn.MouseButton1Click:Connect(function()
    elTypeIdx = (elTypeIdx % #elTypeOptions) + 1
    local t = elTypeOptions[elTypeIdx]
    elTypeBtn.Text = "◀  " .. t .. "  ▶"
    Config.ElephantTeam.Type = t
    -- Auto set defaults
    if t == "RBH Elephant" then
        Config.Target.LevelBefore = 40
        Config.Target.Weight = 5.5
    else
        Config.Target.LevelBefore = 50
        Config.Target.Weight = 3.5
    end
end)

InputBox("Level Before Elephant (RBH=40 / Ele=50)", Config.Target.LevelBefore, function(v)
    Config.Target.LevelBefore = tonumber(v) or 50
end)
InputBox("Target Weight KG (RBH=5.5 / Ele=3.5)", Config.Target.Weight, function(v)
    Config.Target.Weight = tonumber(v) or 3.5
end)

Divider()

-- AUTO ELEPHANT TOGGLE
Section("🐘  AUTO ELEPHANT V2", C.Purple)

local autoToggle, SetAutoState = Toggle("Enable Auto Elephant V2", false, function(val)
    Config.AutoElephant = val
    if val then
        StatusText.Text = "🟢 Running  |  Leveling Team: 0/" .. Config.LevelingTeam.MaxPets
            .. "  |  Elephant Team: 0/" .. Config.ElephantTeam.MaxPets
    else
        StatusText.Text = "🔴 Stopped  |  Leveling Team: 0/" .. Config.LevelingTeam.MaxPets
            .. "  |  Elephant Team: 0/" .. Config.ElephantTeam.MaxPets
    end
end)

-- ================================================
-- DRAGGABLE
-- ================================================
local dragging, dragStart, startPos
TitleBar.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = inp.Position
        startPos = MainFrame.Position
    end
end)
TitleBar.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)
UserInputService.InputChanged:Connect(function(inp)
    if dragging and (inp.UserInputType == Enum.UserInputType.MouseMovement
        or inp.UserInputType == Enum.UserInputType.Touch) then
        local d = inp.Position - dragStart
        MainFrame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + d.X,
            startPos.Y.Scale, startPos.Y.Offset + d.Y
        )
    end
end)

-- ================================================
-- MINIMIZE / CLOSE
-- ================================================
local minimized = false
MinBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    Scroll.Visible = not minimized
    MainFrame.Size = minimized
        and UDim2.new(0, 460, 0, 48)
        or UDim2.new(0, 460, 0, 600)
    MinBtn.Text = minimized and "+" or "–"
end)

CloseBtn.MouseButton1Click:Connect(function()
    ScreenGui:Destroy()
end)

-- ================================================
-- AUTO ELEPHANT LOOP
-- ================================================
local function GetPetLevel(pet)
    if not pet or not pet.Instance then return 0 end
    return pet.Instance:GetAttribute("Level")
        or pet.Instance:GetAttribute("PetLevel")
        or pet.Level or 0
end

local function GetPetWeight(pet)
    if not pet or not pet.Instance then return 0 end
    return pet.Instance:GetAttribute("Weight")
        or pet.Instance:GetAttribute("PetWeight")
        or pet.Weight or 0.0
end

local tick_interval = 0
RunService.Heartbeat:Connect(function(dt)
    if not Config.AutoElephant then return end
    tick_interval = tick_interval + dt
    if tick_interval < 1 then return end -- update per 1 detik
    tick_interval = 0

    local targetPet = Config.Target.Pet
    if not targetPet then
        StatusText.Text = "⚠️  Target pet belum dipilih!"
        return
    end

    local currentLevel = GetPetLevel(targetPet)
    local currentWeight = GetPetWeight(targetPet)
    local levelTarget = Config.Target.LevelBefore
    local weightTarget = Config.Target.Weight

    if currentWeight >= weightTarget then
        Config.AutoElephant = false
        SetAutoState(false)
        StatusText.Text = "✅ Target weight tercapai! " .. targetPet.Name
            .. " = " .. string.format("%.2f", currentWeight) .. " kg"
        return
    end

    if currentLevel < levelTarget then
        -- Gunakan Leveling Team
        StatusText.Text = "🟢 Leveling  |  " .. targetPet.Name
            .. "  Lv." .. currentLevel .. "/" .. levelTarget
            .. "  |  " .. string.format("%.2f", currentWeight) .. " kg"
        -- TODO: Hook equip leveling team ke remote game
    else
        -- Ganti ke Elephant Team
        StatusText.Text = "🐘 Elephant  |  " .. targetPet.Name
            .. "  Lv." .. currentLevel
            .. "  |  " .. string.format("%.2f", currentWeight)
            .. "/" .. weightTarget .. " kg"
        -- TODO: Hook equip elephant team ke remote game
    end
end)

print("✅ [GaG Script] Loaded Successfully!")
